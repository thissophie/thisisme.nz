---
import Layout from "../layouts/Layout.astro";

const socialLinks = [
  // {
  //   id: "mastodon",
  //   name: "cloudisland.nz/@patrick",
  //   description: "Follow them on Mastodon",
  //   url: "https://cloudisland.nz/@patrick",
  //   icon: "🐘"
  // }
  /*  {
    id: "instagram",
    name: "Instagram",
    description: "Visual stories and inspiration",
    url: "https://instagram.com",
    icon: "📷",
  },
  {
    id: "linkedin",
    name: "LinkedIn",
    description: "Professional experience and portfolio",
    url: "https://linkedin.com",
    icon: "💼",
  },
  {
    id: "github",
    name: "GitHub",
    description: "Code projects and contributions",
    url: "https://github.com",
    icon: "{",
  },
  {
    id: "email",
    name: "Email",
    description: "Get in touch directly",
    url: "mailto:hello@example.com",
    icon: "✉",
  },
  {
    id: "website",
    name: "Personal Website",
