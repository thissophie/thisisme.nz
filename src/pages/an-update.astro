---
import Layout from "../layouts/Layout.astro";
---

<Layout title="hello, I'm Sophie Quinn-Graham" description="An update about who I am.">
  <div
    class="min-h-screen bg-background text-foreground transition-colors duration-300"
  >
    <main class="flex items-center justify-center min-h-screen px-4">
      <div class="w-full max-w-2xl">
        <div class="mb-16">
          <div class="mb-12 flex justify-start">
            <div
              class="relative w-24 h-24 rounded-full overflow-hidden bg-muted flex-shrink-0"
            >
              <img
                alt="thisisme's profile picture"
                width="96"
                height="96"
                decoding="async"
                data-nimg="1"
                class="w-full h-full object-cover"
                src="/avatar.png"
                style="color: transparent;"
              />
            </div>
          </div><div class="space-y-6">
            <div>
              <h1
                class="text-4xl md:text-5xl font-heading font-medium leading-tight tracking-tight text-accent"
              >
                hello, I'm Sophie Quinn-Graham
              </h1>
            </div>
            <div class="space-y-4">
              <h2 class="text-lg font-heading text-foreground/80 leading-relaxed max-w-xl">
                my pronouns are she/her
              </h2>
              <p class="text-base text-foreground/60 leading-relaxed max-w-xl">
                You likely know me by another name, Patrick. I don't dislike that name, but now is the time to start to change that. The real world is eventually consistent, and with that it's going to take me some time to filter this update across all the social and professional groups I exist in. I'm not going to get upset if you don't know this, but I'd appreciate you making the effort and updating any references to me that you might have.
              </p>
            </div>
          </div>
        </div>
      </div>
    </main>
  </div>
</Layout>
