---
import type { HTMLAttributes } from "astro/types";

type Props = HTMLAttributes<"a">;

const { href, class: className, ...props } = Astro.props;
---

<a
  href={href}
  class:list={[
    "text-purple-900",
    "contrast-more:font-bold",
    "opacity-95",
    "underline",
    "hover:text-purple-700",
    className,
  ]}
  {...props}><slot /></a
>
